    {
      "cell_type": "code",
      "source": [
        "def myPow(x,n):\n",
        "  y=1\n",
        "  if n==0:\n",
        "    return 1\n",
        "  for i in range(n):\n",
        "    y=y*x\n",
        "  return y\n",
        "\n",
        "x=int(input(\"Enter a non-negative number (base): \"))\n",
